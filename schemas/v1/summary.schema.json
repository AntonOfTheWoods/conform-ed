{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conform-ed.dev/schemas/v1/summary.schema.json",
  "title": "Conform-ed Runner Summary",
  "type": "object",
  "required": ["contractVersion", "runner", "startedAt", "finishedAt", "durationMs", "result", "artifacts"],
  "properties": {
    "contractVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "runner": {
      "type": "object",
      "required": ["suite", "version", "profileVersion", "target"],
      "properties": {
        "suite": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$" },
        "profileVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "target": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "result": {
      "type": "object",
      "required": ["status", "passed", "failed", "skipped"],
      "properties": {
        "status": { "enum": ["passed", "failed", "error"] },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "adapter": {
      "type": "object",
      "required": ["name", "version", "profileVersion"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "profileVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["summaryFile", "junitFile", "requirementTraceFile", "runMetadataFile"],
      "properties": {
        "summaryFile": { "type": "string", "minLength": 1 },
        "junitFile": { "type": "string", "minLength": 1 },
        "requirementTraceFile": { "type": "string", "minLength": 1 },
        "runMetadataFile": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
