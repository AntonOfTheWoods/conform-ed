{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conform-ed.dev/schemas/v1/requirement-trace.schema.json",
  "title": "Conform-ed Requirement Trace",
  "type": "object",
  "required": ["contractVersion", "runId", "requirements"],
  "properties": {
    "contractVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "runId": { "type": "string", "minLength": 1 },
    "requirements": {
      "type": "object",
      "propertyNames": { "type": "string", "minLength": 1 },
      "additionalProperties": {
        "type": "object",
        "required": ["status", "evidence"],
        "properties": {
          "status": { "enum": ["passed", "failed", "skipped", "error"] },
          "evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "message": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
