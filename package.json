{
  "name": "conform-ed",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --config .oxlintrc.jsonc . && turbo run lint",
    "format": "oxfmt --config .oxfmtrc.jsonc --check . && turbo run format",
    "check": "bun run typecheck && bun run lint && bun run test",
    "validate": "bun run format && bun run check",
    "validate:full": "bun run validate",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "images:build": "bun run scripts/build-images.ts",
    "images:publish:ghcr": "bun run scripts/publish-ghcr.ts",
    "test:lrs": "bun run --cwd apps/lrs-runner test",
    "test:cmi5": "bun run --cwd apps/cmi5-runner test",
    "test:lti13": "bun run --cwd apps/lti13-runner test"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/bun": "^1.3.14",
    "@typescript/native-preview": "^7.0.0-dev.20260522.1",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.5.0",
    "zod": "^4.4.3"
  },
  "packageManager": "bun@1.3.14"
}
